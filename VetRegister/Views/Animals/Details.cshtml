@model AddAndEditAnimalFormModel

@{
    ViewData["Title"] = "Details for Animal";
}


<form>
    <div class="form-group row">
        <label for="Name" class="col-sm-2 col-form-label">Name:</label>
        <a for="Name" class="col-sm-10 col-form-label">@Model.Name</a>
    </div>
    <div class="form-group row">
        <label for="Age" class="col-sm-2 col-form-label">Age:</label>
        <a for="Age" class="col-sm-10 col-form-label">@Model.Age</a>
    </div>
    <div class="form-group row">
        <label for="Owner" class="col-sm-2 col-form-label">Owner:</label>
        <a for="Owner" class="col-sm-10 col-form-label">@Model.Owner</a>
    </div>
    <div class="form-group row">
        <label for="Breed" class="col-sm-2 col-form-label">Breed:</label>
        <a for="Breed" class="col-sm-10 col-form-label">@Model.BreedName</a>
    </div>
</form>
