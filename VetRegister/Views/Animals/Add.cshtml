
@model AnimalFormModel 

@{ 
    ViewData["Title"] = "Add Animal";
}

<form method="post">
    <div class="form-group">
        <label asp-for="Name"></label>
        <input asp-for="Name" class="form-control" placeholder="Give me a name">
        <span asp-validation-for="Name" class="small text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="DateOfBirth"></label>
        <input asp-for="DateOfBirth" class="form-control" placeholder="Give me a birday.">
        <span asp-validation-for="DateOfBirth" class="small text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="BreedId">Breed:</label>
        <select asp-for="BreedId" class="form-control">
            @foreach (var breed in Model.Breeds)
            {
                <option value="@breed.Id">@breed.Name</option>
            }
        </select>
    </div>
    @*<div class="form-group">
        <label for="exampleFormControlTextarea1">Example textarea</label>
        <textarea class="form-control" id="exampleFormControlTextarea1" rows="3"></textarea>
    </div>*@
    <input class="btn btn-primary float-right" type="submit" value="Save" />
</form>