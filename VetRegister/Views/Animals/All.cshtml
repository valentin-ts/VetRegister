@model AllAnimalsQueryModel

@{
    ViewData["Title"] = "View All Animals";
}

<form method="get">

    <table class="table table-striped table-bordered">
        <thead>
            <tr>
                <th scope="col">
                    <label asp-for="NameFilter"></label>
                    <input asp-for="NameFilter" class="form-control" placeholder="Add Filter ...">
                </th>
                <th scope="col">
                    <label asp-for="BreedFilter"></label>
                    <select asp-for="BreedFilter" class="form-control" placeholder="Add Filter ...">
                        <option value="">All Breeds ...</option>
                        @foreach (var breed in Model.Breeds)
                        {
                            <option value="@breed">@breed</option>
                        }
                    </select>
                </th>
                <th scope="col">
                    <label asp-for="DateOfBirthFilter"></label>
                    <input asp-for="DateOfBirthFilter" class="form-control" placeholder="Add Filter ...">
                </th>
                <th scope="col">
                    <label asp-for="AgeFilter"></label>
                    <input asp-for="AgeFilter" class="form-control" placeholder="Add Filter ...">
                </th>
                <th scope="col">
                    <input class="btn btn-primary" type="submit" value="Apply Search Filters" />
                </th>
            </tr>
        </thead>
        <tbody>
            @foreach (var animal in Model.Animals)
            {
                <tr>
                    <td>@animal.Name</td>
                    <td>@animal.BreedName</td>
                    <td>@animal.DateOfBirth</td>
                    <td>@animal.Age</td>
                    <td>
                        <a class="btn btn-primary" asp-controller="Animals" asp-action="Details" asp-route-id="@animal.Id">Details</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</form>



