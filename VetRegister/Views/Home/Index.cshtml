@{
    ViewData["Title"] = "Home Page";
}

@using Microsoft.AspNetCore.Identity
@using System.Security.Claims;

@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager
@inject IPersonService Persons

@if (SignInManager.IsSignedIn(User))
{
    var userId = User.FindFirst(ClaimTypes.NameIdentifier).Value;

    if (Persons.IsDoctor(userId))
    {
        <div class="text-center">
            <h1 class="display-4">Doctor</h1>
        </div>
    }

    else if (Persons.IsOwner(userId))
    {
        <div class="text-center">
            <h1 class="display-4">Owner</h1>
        </div>
    }

    else
    {
        <br>
        <div class="text-center">
            <a class="text-body">You have not yet registered as Doctor or Owner. You must choose your destiny!</a>
            <br>
            <br>
            <a class="btn btn-primary" asp-area="" asp-controller="Persons" asp-action="BecomeDoctor">Register as Doctor</a>
            <a class="btn btn-primary" asp-area="" asp-controller="Persons" asp-action="BecomeOwner">Register as Owner</a>
        </div>
    }
}
else
{
    <div class="text-center">
        <h1 class="display-4">Not registered</h1>
    </div>
}
